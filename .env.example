# ── GeoGuard Environment Configuration ──────────────────────

# Database
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=geoguard-influx-token
INFLUXDB_ORG=geoguard
INFLUXDB_BUCKET=sensor-data

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=geoguard
POSTGRES_PASSWORD=geoguard_admin
POSTGRES_DB=geoguard

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=geoguard/sensor/data

# NASA Earthdata (register at https://urs.earthdata.nasa.gov)
NASA_EARTHDATA_USERNAME=
NASA_EARTHDATA_PASSWORD=
NASA_EARTHDATA_TOKEN=

# ESA Copernicus (register at https://scihub.copernicus.eu)
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=

# DHM Rainfall API (endpoint TBD — scraper fallback built in)
DHM_API_URL=
DHM_API_KEY=

# BIPAD API (optional — required for live BIPAD incidents/alerts ingestion)
BIPAD_API_BASE=https://bipadportal.gov.np/api/v1
BIPAD_API_TOKEN=
BIPAD_USERNAME=
BIPAD_PASSWORD=

# Sensor API
SENSOR_API_SECRET=geoguard-dev-secret-change-in-prod
SENSOR_API_PORT=3000

# AWS S3 (cold archive — optional for dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=geoguard-archive
AWS_REGION=ap-south-1

# Dashboard
DASHBOARD_API_PORT=8000
DASHBOARD_FRONTEND_PORT=3001

# Google Maps API
VITE_GOOGLE_MAPS_API_KEY=
